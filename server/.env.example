# ===========================================
# 英语能力测评与课程服务系统 - 环境变量配置示例
# ===========================================
# 复制此文件为 .env 并填入真实值

# ---------- 数据库配置 ----------
# PostgreSQL 数据库连接信息
# 获取方式: 在 PostgreSQL 中创建数据库和用户
DATABASE_URL=postgresql://username:password@localhost:5432/english_learning
DB_HOST=localhost
DB_PORT=5432
DB_NAME=english_learning
DB_USER=username
DB_PASSWORD=your_password

# ---------- Redis 配置 (可选) ----------
# 用于缓存和会话存储，如不使用可留空
REDIS_URL=redis://localhost:6379

# ---------- 服务器配置 ----------
PORT=9091
NODE_ENV=development

# ---------- JWT 认证 ----------
# JWT 密钥: 生产环境请使用随机生成的强密钥 (至少32字符)
JWT_SECRET=change_this_to_a_random_secret_key_at_least_32_chars
JWT_EXPIRES_IN=7d

# ---------- 科大讯飞语音评测 API ----------
# 申请地址: https://console.xfyun.cn/services/ise
# 功能: 口语发音评测、流式语音识别
IFLYTEK_APP_ID=your_app_id_from_xfyun_console
IFLYTEK_API_KEY=your_api_key_from_xfyun_console
IFLYTEK_API_SECRET=your_api_secret_from_xfyun_console

# ---------- LLM 服务配置 (通义千问/Doubao) ----------
# 通义千问申请: https://dashscope.console.aliyun.com/
# Doubao申请: https://console.volcengine.com/
# 功能: AI外教对话、报告生成、内容推荐
DASHSCOPE_API_KEY=your_dashscope_api_key

# ---------- 微信支付配置 ----------
# 微信商户平台: https://pay.weixin.qq.com/
# 功能: 小程序支付、H5支付、扫码支付
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_merchant_id
WECHAT_API_KEY=your_wechat_api_key_32_chars
WECHAT_SERIAL_NO=your_certificate_serial_no_from_wechat_pay
WECHAT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
your_private_key_content_here
-----END PRIVATE KEY-----"
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify

# ---------- 微信小程序配置 ----------
# 微信公众平台: https://mp.weixin.qq.com/
WECHAT_MINI_APP_ID=your_mini_program_app_id
WECHAT_MINI_APP_SECRET=your_mini_program_app_secret

# ---------- 企业微信配置 ----------
# 企业微信管理后台: https://work.weixin.qq.com/
# 功能: 教师工作台、消息推送、家长沟通
WECOM_CORP_ID=your_corp_id
WECOM_CORP_SECRET=your_corp_secret
WECOM_AGENT_ID=your_agent_id

# ---------- 短信服务配置 ----------
# 阿里云短信: https://dysms.console.aliyun.com/
# 功能: 用户注册验证、订单通知、考前提醒
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=英语学习平台
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx

# ---------- 对象存储配置 ----------
# 腾讯云 COS: https://console.cloud.tencent.com/cos
# 功能: 存储用户头像、测评报告音频、课程视频
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=english-learning-assets
COS_REGION=ap-guangzhou

# ---------- 前端配置 ----------
# 各端访问地址
FRONTEND_URL=http://localhost:5000
ADMIN_URL=http://localhost:3000
H5_URL=https://your-h5-domain.com

# ---------- 邮件服务配置 (可选) ----------
# 用于发送邮件通知
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@english-learning.com
SMTP_PASSWORD=your_smtp_password

# ---------- 极光推送配置 (可选) ----------
# 功能: App推送通知
JIGUANG_APP_KEY=your_jiguang_app_key
JIGUANG_MASTER_SECRET=your_jiguang_master_secret

# ---------- 微信模板消息配置 ----------
# 在微信公众平台模板消息库中选择
# 功能: 测评完成通知、考试提醒、课后报告推送
WECHAT_TEMPLATE_ASSESSMENT=your_assessment_complete_template_id
WECHAT_TEMPLATE_EXAM=your_exam_reminder_template_id
WECHAT_TEMPLATE_MOCK_EXAM=your_mock_exam_template_id
WECHAT_TEMPLATE_CLASS=your_class_schedule_template_id
WECHAT_TEMPLATE_REPORT=your_report_template_id
WECHAT_TEMPLATE_PAYMENT=your_payment_template_id
WECHAT_TEMPLATE_EXAM_READY=your_exam_ready_template_id
WECHAT_TEMPLATE_PROGRESS=your_progress_template_id
WECHAT_TEMPLATE_SYSTEM=your_system_notification_template_id

# ---------- 日志配置 ----------
LOG_LEVEL=info

# ---------- QR Code 服务配置 ----------
# 用于生成渠道二维码
QR_SERVER_URL=https://api.qrserver.com/v1/create-qr-code

# ---------- 考试配置 ----------
# 考试报名服务费
EXAM_REGISTRATION_BASIC_FEE=99
EXAM_REGISTRATION_VIP_FEE=199
EXAM_REGISTRATION_GROUP_FEE=79

# 模拟考试定价
MOCK_EXAM_PRICE=29.9
KET_CRASH_COURSE_PRICE=199
PET_CRASH_COURSE_PRICE=249
