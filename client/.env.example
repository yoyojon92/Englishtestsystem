# ===========================================
# 英语能力测评与课程服务系统 - 客户端环境变量
# ===========================================
# 复制此文件为 .env 并填入真实值

# ---------- API 配置 ----------
# 后端 API 地址
EXPO_PUBLIC_API_BASE_URL=http://localhost:9091/api/v1

# ---------- 微信小程序配置 ----------
# 微信公众平台: https://mp.weixin.qq.com/
EXPO_PUBLIC_WECHAT_APP_ID=your_mini_program_app_id

# ---------- 对象存储配置 ----------
# 腾讯云 COS 公开访问地址前缀
EXPO_PUBLIC_COS_BASE_URL=https://your-bucket.cos.ap-guangzhou.myqcloud.com

# ---------- 主题配置 ----------
# 可选值: light (亮色) / dark (暗色) / system (跟随系统)
EXPO_PUBLIC_THEME=system

# ---------- 功能开关 ----------
# 是否启用 AI 外教功能
EXPO_PUBLIC_ENABLE_AI_TEACHER=true

# 是否启用语音评测
EXPO_PUBLIC_ENABLE_SPEECH_EVAL=true

# ---------- 统计分析 ----------
# 用于统计用户行为数据 (可选)
EXPO_PUBLIC_GA_MEASUREMENT_ID=
