# ===========================================
# Expo 客户端 - 环境变量配置
# ===========================================

# 后端 API 地址
EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:9091

# 微信小程序 AppID (如需微信登录)
EXPO_PUBLIC_WECHAT_APP_ID=your_wechat_app_id

# 讯飞语音评测 (如需录音评测)
EXPO_PUBLIC_IFLYTEK_APP_ID=your_app_id
